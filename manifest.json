{
  "name": "Media Viewer",
  "version": "3.1.2",
  "entry": "index.js",
  "description": "Universal media display widget supporting images, videos, audio files, GIFs, and video platforms (YouTube, Vimeo, Twitch, Dailymotion).",
  "author": "MyWallpaper Community",
  "categories": [
    "media",
    "utilities",
    "display"
  ],
  "license": "MIT",
  "repository": "https://github.com/MyWallpapers/mywallpaper-addon-media-viewer",
  "permissions": {
    "storage": {
      "quota": 256
    },
    "network": {
      "domains": [
        "*"
      ]
    },
    "audio": true
  },
  "settings": {
    "mediaSection": {
      "type": "section",
      "content": {
        "label": "Media Source"
      }
    },
    "sourceType": {
      "type": "select",
      "content": {
        "label": "Source Type",
        "description": "Choose how to provide the media",
        "default": "url",
        "options": [
          {
            "value": "url",
            "label": "From URL"
          },
          {
            "value": "file",
            "label": "Upload File"
          }
        ]
      }
    },
    "mediaUrl": {
      "type": "string",
      "content": {
        "label": "Media URL",
        "description": "Direct link to image/video/audio, or YouTube/Vimeo/Twitch/Dailymotion URL",
        "default": "",
        "placeholder": "https://youtube.com/watch?v=... or https://example.com/video.mp4",
        "showIf": {
          "setting": "sourceType",
          "equals": "url"
        }
      }
    },
    "mediaFile": {
      "type": "file",
      "content": {
        "label": "Upload Media",
        "description": "Upload a local image, video, or audio file",
        "showIf": {
          "setting": "sourceType",
          "equals": "file"
        }
      }
    },
    "displaySection": {
      "type": "section",
      "content": {
        "label": "Display Options"
      }
    },
    "objectFit": {
      "type": "select",
      "content": {
        "label": "Scaling Mode",
        "description": "How the media should fit within the widget",
        "default": "contain",
        "options": [
          {
            "value": "contain",
            "label": "Fit (show all)"
          },
          {
            "value": "cover",
            "label": "Cover (fill area)"
          },
          {
            "value": "fill",
            "label": "Stretch"
          },
          {
            "value": "none",
            "label": "Original Size"
          },
          {
            "value": "scale-down",
            "label": "Scale Down Only"
          }
        ]
      }
    },
    "objectPosition": {
      "type": "select",
      "content": {
        "label": "Position",
        "description": "Alignment when media doesn't fill the widget",
        "default": "center",
        "options": [
          {
            "value": "center",
            "label": "Center"
          },
          {
            "value": "top",
            "label": "Top"
          },
          {
            "value": "bottom",
            "label": "Bottom"
          },
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "right",
            "label": "Right"
          },
          {
            "value": "top left",
            "label": "Top Left"
          },
          {
            "value": "top right",
            "label": "Top Right"
          },
          {
            "value": "bottom left",
            "label": "Bottom Left"
          },
          {
            "value": "bottom right",
            "label": "Bottom Right"
          }
        ]
      }
    },
    "backgroundColor": {
      "type": "color",
      "content": {
        "label": "Background Color",
        "description": "Color shown behind the media or as fallback",
        "default": "#00000000"
      }
    },
    "borderRadius": {
      "type": "range",
      "content": {
        "label": "Corner Radius",
        "description": "Rounded corners (in pixels)",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 0
      }
    },
    "videoSection": {
      "type": "section",
      "content": {
        "label": "Playback Options"
      }
    },
    "autoplay": {
      "type": "boolean",
      "content": {
        "label": "Autoplay",
        "description": "Start playback automatically",
        "default": true
      }
    },
    "loop": {
      "type": "boolean",
      "content": {
        "label": "Loop",
        "description": "Repeat media when it ends",
        "default": true
      }
    },
    "muted": {
      "type": "boolean",
      "content": {
        "label": "Muted",
        "description": "Play without sound (required for autoplay in most browsers)",
        "default": true
      }
    },
    "volume": {
      "type": "range",
      "content": {
        "label": "Volume",
        "description": "Audio volume level (0-100%)",
        "min": 0,
        "max": 100,
        "step": 5,
        "default": 80
      }
    },
    "showControls": {
      "type": "boolean",
      "content": {
        "label": "Show Controls",
        "description": "Display playback controls (direct videos/audio only)",
        "default": false
      }
    },
    "playbackRate": {
      "type": "range",
      "content": {
        "label": "Playback Speed",
        "description": "Playback speed multiplier (direct media only)",
        "min": 0.25,
        "max": 2,
        "step": 0.25,
        "default": 1
      }
    },
    "effectsSection": {
      "type": "section",
      "content": {
        "label": "Visual Effects"
      }
    },
    "opacity": {
      "type": "range",
      "content": {
        "label": "Opacity",
        "description": "Media transparency (0-100%)",
        "min": 0,
        "max": 100,
        "step": 1,
        "default": 100
      }
    },
    "blur": {
      "type": "range",
      "content": {
        "label": "Blur",
        "description": "Gaussian blur effect (in pixels)",
        "min": 0,
        "max": 50,
        "step": 1,
        "default": 0
      }
    },
    "brightness": {
      "type": "range",
      "content": {
        "label": "Brightness",
        "description": "Brightness adjustment (100% = normal)",
        "min": 0,
        "max": 200,
        "step": 5,
        "default": 100
      }
    },
    "contrast": {
      "type": "range",
      "content": {
        "label": "Contrast",
        "description": "Contrast adjustment (100% = normal)",
        "min": 0,
        "max": 200,
        "step": 5,
        "default": 100
      }
    },
    "saturate": {
      "type": "range",
      "content": {
        "label": "Saturation",
        "description": "Color saturation (100% = normal, 0% = grayscale)",
        "min": 0,
        "max": 200,
        "step": 5,
        "default": 100
      }
    },
    "hueRotate": {
      "type": "range",
      "content": {
        "label": "Hue Rotate",
        "description": "Shift all colors around the color wheel (in degrees)",
        "min": 0,
        "max": 360,
        "step": 15,
        "default": 0
      }
    },
    "advancedSection": {
      "type": "section",
      "content": {
        "label": "Advanced"
      }
    },
    "fallbackText": {
      "type": "string",
      "content": {
        "label": "Fallback Text",
        "description": "Text shown when media fails to load",
        "default": "Media unavailable"
      }
    },
    "refreshInterval": {
      "type": "range",
      "content": {
        "label": "Auto-Refresh (minutes)",
        "description": "Reload media periodically (0 = disabled). Useful for webcams or updating images.",
        "min": 0,
        "max": 60,
        "step": 1,
        "default": 0,
        "showIf": {
          "setting": "sourceType",
          "equals": "url"
        }
      }
    }
  },
  "defaultLayout": {
    "xPercent": 50,
    "yPercent": 50,
    "widthPercent": 40,
    "heightPercent": 50
  },
  "ui": {
    "pointerEvents": "none"
  }
}
